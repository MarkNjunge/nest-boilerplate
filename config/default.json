{
  "appName": "nest-boilerplate",
  "appVersion": "0.1.0",
  "env": "development",
  "port": 3000,
  "auth": {
    "adminKey": "api-key"
  },
  "apiKey": "api-key",
  "db": {
    "url": "postgres://username:password@localhost:5432/database",
    "poolSize": 50,
    "logQueries": false,
    "logQueryBindings": true,
    "runMigrations": true,
    "connectTimeoutMS": 5000,
    "retryAttempts": 10,
    "retryDelay": 3000,
    "queryTimeout": 30000
  },
  "redis": {
    "url": "redis://localhost:6379",
    "connectTimeout": 5000,
    "logCommands": true,
    "keyPrefix": "nb:"
  },
  "swagger": {
    "enabled": true,
    "endpoint": "docs"
  },
  "rateLimit": {
    "enabled": true,
    "max": 100,
    "timeWindow": 60
  },
  "cors": {
    "origins": "*",
    "methods": "*",
    "allowedHeaders": "*"
  },
  "validator": {
    "forbidUnknown": true,
    "nonStrictQuery": true
  },
  "logging": {
    "logDataConsole": false
  },
  "fileUpload": {
    "maxSize": 5242880,
    "removeAfterUpload": true,
    "_uploadDir": "See README"
  },
  "instrumentation": {
    "enabled": false,
    "debug": false,
    "sampleRatio": 1,
    "tracing": {
      "enabled": true,
      "url": "http://localhost:4318/v1/traces"
    },
    "metrics": {
      "enabled": true,
      "url": "http://localhost:4318/v1/metrics"
    },
    "logs": {
      "enabled": true,
      "url": "http://localhost:4318/v1/logs",
      "logData": true,
      "logRequestData": false,
      "logResponseData": false
    }
  },
  "integrationTest": {
    "pgImage_": "postgres:18.0-alpine3.22",
    "pgImage": "postgres@sha256:48c8ad3a7284b82be4482a52076d47d879fd6fb084a1cbfccbd551f9331b0e40",
    "redisImage_": "redis:8.8.0-alpine3.23",
    "redisImage": "redis@sha256:9d317178eceac8454a2284a9e6df2466b93c745529947f0cd42a0fa9609d7005",
    "logQueries": false
  }
}
