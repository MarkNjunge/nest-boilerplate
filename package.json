{
  "name": "nest-boilerplate",
  "version": "0.1.0",
  "description": "A starter template for NestJS with support for database, swagger, config, logging, validation, exception handling, docker, testing and CI.",
  "author": "Mark Njung'e",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "prebuild": "rimraf dist",
    "build": "nest build",
    "docs": "npx compodoc -p tsconfig.json -s",
    "start": "nest start -b swc --type-check",
    "start:dev": "nest start --watch -b swc --type-check",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "start:e2e": "nest start -b swc",
    "codegen": "cross-env NODE_OPTIONS='--import tsx' node_modules/plop/bin/plop.js --plopfile=plopfile.ts",
    "migration": "cross-env NODE_OPTIONS='--import tsx' node scripts/migration.ts",
    "lint": "eslint \"{src,apps,libs,test,scripts}/**/*.{ts,js}\"",
    "lint:fix": "eslint \"{src,apps,libs,test,scripts}/**/*.{ts,js}\" --fix",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "docker compose -f docker-compose-e2e.yml up --abort-on-container-exit --exit-code-from test",
    "posttest:e2e": "docker compose -f docker-compose-e2e.yml down --rmi all",
    "test:e2e:local": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/otel": "^0.18.1",
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/platform-fastify": "^11.1.19",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.215.0",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/core": "^2.7.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.215.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.215.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-logs": "^0.215.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "chokidar": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "config": "^4.4.1",
    "dayjs": "^1.11.20",
    "lodash": "^4.18.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28",
    "ulid": "^3.0.2",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0"
  },
  "devDependencies": {
    "@compodoc/compodoc": "^1.2.1",
    "@eslint/js": "^9.30.1",
    "@marknjunge/eslint-config-ts": "^3.1.0",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.13.2",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/flat": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.10.0",
    "@types/pluralize": "^0.0.33",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "plop": "^4.0.5",
    "pluralize": "^8.0.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".spec.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "diagnostics": {
            "ignoreCodes": [
              151001
            ]
          }
        }
      ]
    },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "setupFiles": [
      "../test/util/logging.ts"
    ],
    "moduleNameMapper": {
      "@/(.*)": [
        "<rootDir>/$1"
      ]
    },
    "testTimeout": 30000
  }
}
