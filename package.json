{
  "name": "nest-boilerplate",
  "version": "0.1.0",
  "description": "A starter template for NestJS with support for database, swagger, config, logging, validation, exception handling, docker, testing and CI.",
  "author": "Mark Njung'e",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "prebuild": "rimraf dist",
    "build": "nest build",
    "start": "nest start -b swc --type-check",
    "start:dev": "nest start --watch -b swc --type-check",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "start:e2e": "nest start -b swc",
    "codegen": "cross-env NODE_OPTIONS='--import tsx' node_modules/plop/bin/plop.js --plopfile=src/lib/crud/plopfile.ts",
    "migration": "cross-env NODE_OPTIONS='--import tsx' node scripts/migration.ts",
    "lint": "eslint \"{src,e2e-test,scripts,load-test}/**/*.{ts,js}\"",
    "lint:fix": "eslint \"{src,e2e-test,scripts,load-test}/**/*.{ts,js}\" --fix",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "docker compose -f docker-compose-e2e.yml up --no-attach redis --no-attach postgres --no-attach app --abort-on-container-exit --exit-code-from test",
    "posttest:e2e": "docker compose -f docker-compose-e2e.yml down --rmi all",
    "test:e2e:local": "jest --verbose --config e2e-test/jest-e2e.config.mjs",
    "load-test": "API_KEY=${API_KEY:-api-key} artillery run --environment ${LOAD_TYPE:-validation} --output load-test/report.json --target ${API_HOST:-http://localhost:3000} load-test/test.yml && npm run load-test:report",
    "load-test:report": "npx tsx load-test/generate-report.ts",
    "load-test:validation": "cross-env LOAD_TYPE=validation npm run load-test",
    "load-test:spike": "cross-env LOAD_TYPE=spike npm run load-test",
    "load-test:soak": "cross-env LOAD_TYPE=soak npm run load-test",
    "load-test:scenario": "API_KEY=${API_KEY:-api-key} artillery run --scenario-name \"${SCENARIO}\" --environment ${LOAD_TYPE:-validation} --output load-test/report.json --target ${API_HOST:-http://localhost:3000} load-test/test.yml && npm run load-test:report",
    "load-test:crud-only": "cross-env SCENARIO='User CRUD lifecycle' npm run load-test:scenario",
    "load-test:browse-only": "cross-env SCENARIO='Browse users' npm run load-test:scenario",
    "load-test:search-only": "cross-env SCENARIO='User search' npm run load-test:scenario",
    "load-test:template:dev": "live-server --open=/template.html load-test"
  },
  "dependencies": {
    "@fastify/helmet": "^13.1.0",
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^9.1.3",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-fastify": "^11.1.28",
    "@nestjs/swagger": "^11.4.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.3",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.220.0",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/core": "^2.9.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-metrics-otlp-proto": "^0.220.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-logs": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.43.0",
    "@testcontainers/redis": "^12.0.4",
    "chokidar": "^5.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "config": "^4.4.2",
    "dayjs": "^1.11.21",
    "lodash": "^4.18.1",
    "pg": "^8.22.0",
    "redis": "^6.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^1.1.0",
    "ulid": "^3.0.2",
    "winston": "^3.19.0",
    "winston-transport": "^4.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.5.0",
    "@marknjunge/eslint-config-ts": "^4.1.0",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@testcontainers/postgresql": "^12.0.4",
    "@types/flat": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^24.10.0",
    "@types/pluralize": "^0.0.33",
    "@types/supertest": "^7.2.1",
    "artillery": "^2.0.33",
    "cross-env": "^10.1.0",
    "live-server": "^1.2.2",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "plop": "^4.0.5",
    "pluralize": "^8.0.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "4.2.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0"
  }
}
